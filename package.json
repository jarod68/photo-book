{
  "name": "photo-book",
  "version": "1.0.0",
  "description": "360° photo viewer",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "npm run test:coverage &&docker buildx build --platform linux/amd64,linux/arm64 --provenance=mode=max --sbom=true --push -t jarod68/photo-book:latest .",
    "docker:deploy": "npm run docker:build",
    "docker:run": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "pg": "^8.13.3",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}

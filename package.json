{
  "name": "photo-book",
  "version": "1.0.0",
  "description": "360° photo viewer",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker compose build",
    "docker:push": "docker compose push",
    "docker:deploy": "npm test && npm run docker:build && npm run docker:push",
    "docker:run": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "pg": "^8.13.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.9.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2",
    "vitest": "^2.1.9"
  }
}
